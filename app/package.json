{
  "name": "butterfly-effect",
  "version": "1.0.0",
  "private": true,
  "overrides": {
    "three": "0.171.0",
    "@types/three": "0.171.0",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "@react-three/drei": "^9.120.4",
    "@react-three/fiber": "^8.17.10",
    "@sanity/client": "^6.22.5",
    "@sentry/react": "^10.53.1",
    "express": "^4.21.2",
    "posthog-js": "^1.376.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.14"
  },
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch src/server/index.ts",
    "build": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:ssr": "vite build --ssr src/server-rendering/entry-server.tsx --outDir dist-ssr",
    "build:all": "npm run build && npm run build:ssr && npm run build:server",
    "build:analyze": "vite build --config vite.analyze.ts && start dist/stats.html",
    "preview": "vite preview",
    "start": "node -e \"process.env.NODE_ENV='production'; require('./dist-server/server/index.js')\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "lint:ci": "eslint src/scene-canvas src/graph-runtime/sprites",
    "lint:all": "eslint .",
    "test": "jest"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@sentry/vite-plugin": "^5.3.0",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/three": "0.171.0",
    "@vitejs/plugin-react": "^6.0.3",
    "dependency-cruiser": "^17.3.6",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "playwright": "^1.61.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "ts-jest": "^29.4.11",
    "tsx": "^4.19.2",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.1.0"
  }
}
